# etcd configuration file for {{ inventory_hostname }}
# Generated by Ansible

ETCD_NAME={{ ansible_hostname }}
ETCD_DATA_DIR={{ etcd_data_dir }}
ETCD_LISTEN_PEER_URLS=http://{{ postgres_dns_name }}:{{ etcd_peer_port }}
ETCD_LISTEN_CLIENT_URLS=http://{{ postgres_dns_name }}:{{ etcd_client_port }},http://127.0.0.1:{{ etcd_client_port }}
ETCD_INITIAL_ADVERTISE_PEER_URLS=http://{{ postgres_dns_name }}:{{ etcd_peer_port }}
ETCD_ADVERTISE_CLIENT_URLS=http://{{ postgres_dns_name }}:{{ etcd_client_port }}
ETCD_INITIAL_CLUSTER={{ groups['postgres_cluster'] | map('extract', hostvars, 'ansible_hostname') | zip(groups['postgres_cluster'] | map('extract', hostvars, 'postgres_dns_name')) | map('join', '=http://') | map('regex_replace', '$', ':' ~ etcd_peer_port) | join(',') }}
ETCD_INITIAL_CLUSTER_STATE=new
ETCD_INITIAL_CLUSTER_TOKEN={{ patroni_scope }}-etcd
