-- PostgreSQL Extensions for Harness TSDB Migration
-- This script initializes the required extensions for TSDB to PostgreSQL migration
-- Generated by Ansible on {{ ansible_date_time.iso8601 }}

-- pg_cron: Schedule recurring tasks within PostgreSQL
-- Requires shared_preload_libraries = 'pg_cron' in postgresql.conf
CREATE EXTENSION IF NOT EXISTS pg_cron VERSION '1.6';

-- pg_partman: Manage partitioned tables for time-series data
-- Used for automatic partition creation and maintenance
CREATE EXTENSION IF NOT EXISTS pg_partman SCHEMA public VERSION '5.2.4';

-- hstore: Store key-value pairs in table columns
-- Built-in contrib module
CREATE EXTENSION IF NOT EXISTS hstore VERSION '1.8';

-- Verify extensions are installed
SELECT 'Extension installation complete' AS status;

SELECT
    extname AS "Extension",
    extversion AS "Version",
    CASE
        WHEN extrelocatable THEN 'Yes'
        ELSE 'No'
    END AS "Relocatable"
FROM pg_extension
WHERE extname IN ('pg_cron', 'pg_partman', 'hstore')
ORDER BY extname;

-- Create partman schema for pg_partman maintenance
CREATE SCHEMA IF NOT EXISTS partman;

-- Display pg_cron configuration
SHOW cron.database_name;

-- Success message
\echo 'PostgreSQL extensions for Harness TSDB migration initialized successfully'
