scope: {{ patroni_scope }}
namespace: /service/
name: {{ ansible_hostname }}

restapi:
  listen: 0.0.0.0:{{ patroni_restapi_port }}
  connect_address: {{ postgres_dns_name }}:{{ patroni_restapi_port }}

etcd:
  hosts: {% for host in groups['postgres_cluster'] %}{{ hostvars[host]['postgres_dns_name'] }}:{{ etcd_client_port }}{% if not loop.last %},{% endif %}{% endfor %}

bootstrap:
  dcs:
    ttl: 30
    loop_wait: 10
    retry_timeout: 10
    maximum_lag_on_failover: 1048576
    postgresql:
      use_pg_rewind: true
      use_slots: true
      parameters:
        max_connections: 100
        # Extensions preload for Harness TSDB migration
        shared_preload_libraries: 'pg_cron'
        cron.database_name: 'postgres'
        # Memory settings
        shared_buffers: {{ (ansible_memtotal_mb * postgres_shared_buffers_ratio) | int }}MB
        effective_cache_size: {{ (ansible_memtotal_mb * postgres_effective_cache_size_ratio) | int }}MB
        # WAL settings
        wal_level: replica
        max_wal_senders: 10
        max_replication_slots: 10
        hot_standby: on

  initdb:
    - encoding: UTF8
    - data-checksums
    - locale: en_US.UTF-8

  pg_hba:
    - local all all trust
    - host all all 127.0.0.1/32 trust
    - host all all 0.0.0.0/0 md5
    - host replication {{ postgres_replication_user }} 0.0.0.0/0 md5

  users:
    {{ postgres_superuser }}:
      password: {{ postgres_superuser_password }}
      options:
        - superuser
    {{ postgres_replication_user }}:
      password: {{ postgres_replication_password }}
      options:
        - replication

postgresql:
  listen: 0.0.0.0:{{ postgres_port }}
  connect_address: {{ postgres_dns_name }}:{{ postgres_port }}
  data_dir: {{ postgres_data_dir }}
  bin_dir: {{ postgres_bin_dir }}
  pgpass: /tmp/pgpass
  authentication:
    replication:
      username: {{ postgres_replication_user }}
      password: {{ postgres_replication_password }}
    superuser:
      username: {{ postgres_superuser }}
      password: {{ postgres_superuser_password }}
  parameters:
    unix_socket_directories: '/var/run/postgresql'
    logging_collector: 'on'
    log_directory: '{{ postgres_log_dir }}'
    log_filename: 'postgresql-%Y-%m-%d_%H%M%S.log'

watchdog:
  mode: off  # Can be enabled for production with proper setup

tags:
  nofailover: false
  noloadbalance: false
  clonefrom: false
  nosync: false
