[Unit]
Description=Redis Sentinel
After=network.target
Requires=redis.service

[Service]
Type=notify
User={{ redis_user }}
Group={{ redis_group }}
ExecStart={{ redis_bin_dir }}/redis-sentinel {{ redis_config_dir }}/sentinel.conf
ExecStop=/bin/kill -s TERM $MAINPID
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
